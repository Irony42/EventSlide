{
  "name": "eventslide",
  "version": "0.0.1",
  "description": "Capture, Share, Project : Bring your party to life with our instant photo sharing software",
  "main": "index.js",
  "scripts": {
    "dev:front": "vite",
    "dev:back": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "dev": "npm run dev:back",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck:front": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:back": "tsc -p tsconfig.json --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck": "npm run typecheck:back && npm run typecheck:front && npm run typecheck:node",
    "build:front": "vite build",
    "build:back": "tsc -p tsconfig.json",
    "build": "npm run build:front && npm run build:back",
    "preview:front": "vite preview",
    "start": "node ./dist/index.js",
    "test": "jest",
    "test:ci": "jest --runInBand --passWithNoTests",
    "execute": "tsc && node ./dist/index"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Irony42/EventSlide.git"
  },
  "jest": {
    "preset": "ts-jest",
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  },
  "author": "Irony42",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/Irony42/EventSlide/issues"
  },
  "homepage": "https://github.com/Irony42/EventSlide#readme",
  "dependencies": {
    "archiver": "6.0.0",
    "bcrypt": "5.1.0",
    "body-parser": "1.20.2",
    "cookie-parser": "1.4.6",
    "express": "^4.18.2",
    "express-session": "1.17.3",
    "multer": "1.4.5-lts.1",
    "passport": "^0.6.0",
    "passport-local": "1.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "sharp": "^0.32.6",
    "sqlite3": "5.1.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/archiver": "^5.3.2",
    "@types/bcrypt": "^5.0.0",
    "@types/cookie-parser": "^1.4.3",
    "@types/express": "^4.17.17",
    "@types/express-session": "^1.17.7",
    "@types/jest": "29.5.1",
    "@types/multer": "^1.4.7",
    "@types/node": "^25.6.0",
    "@types/passport": "^1.0.12",
    "@types/passport-local": "^1.0.35",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10"
  }
}
